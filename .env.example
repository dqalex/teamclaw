# CoMind V3 环境变量配置

# 应用基础 URL（必填，用于 MCP handler 和模板引擎）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Knot AI 平台 API 基础地址（可选，如果使用 Knot 部署模式）
# KNOT_API_BASE=https://your-knot-api-url/apigw/api/v1/agents

# OpenClaw API Token（本地 AI 成员调用时使用）
OPENCLAW_TOKEN=

# OpenClaw Gateway 默认地址（可选，默认 ws://localhost:18789）
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# OpenClaw HTTP 默认端点（可选，默认 http://127.0.0.1:18789）
OPENCLAW_DEFAULT_ENDPOINT=http://127.0.0.1:18789

# Token 加密密钥（建议 32+ 字符随机字符串，用于加密存储 API Token）
# 未设置时 Token 将以明文存储在数据库中
TOKEN_ENCRYPTION_KEY=

# 数据库路径（可选，默认自动检测）
# COMIND_DB_PATH=/path/to/data/teamclaw.db
